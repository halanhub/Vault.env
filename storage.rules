rules_version = '2';
// Deploy to your project or uploads fail with storage/unauthorized:
//   firebase deploy --only storage
// (firebase.json maps this file under "storage": { "rules": "storage.rules" })

service firebase.storage {
  match /b/{bucket}/o {
    // Encrypted vault files
    match /vaults/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Project logo images (public read, owner write)
    match /projectImages/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
