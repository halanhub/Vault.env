# Firebase Configuration
# Create a project at https://console.firebase.google.com
# Enable Authentication: Email/Password + Google (Sign-in method), Firestore, Storage

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional: canonical URLs & Open Graph (e.g. https://yourdomain.com)  -  set in production for SEO
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Optional: npm package name shown in "Use these secrets on your computer" on the project page (default: @vaultenv/cli)
# NEXT_PUBLIC_VAULT_ENV_CLI_PACKAGE=@vaultenv/cli

# Dodo Payments  -  Solo checkout (public URL: payment link or hosted checkout base from Dodo dashboard)
# The app appends metadata_firebase_uid for the signed-in user so webhooks can unlock billing/{uid}.
# NEXT_PUBLIC_CHECKOUT_URL=https://checkout.dodopayments.com/...   or your Payment Link URL

# Dodo Customer Portal (cancel subscription, payment method) — Profile "Manage subscription" button
# Your checkout URL uses a product id (pdt_...). The portal needs your BUSINESS id (different value).
# In Dodo: Sales → Customer → Share invite → copy the Static link. Either paste the full URL:
# NEXT_PUBLIC_DODO_CUSTOMER_PORTAL_LOGIN_URL=https://customer.dodopayments.com/login/YOUR_BUSINESS_ID
# Or only the id (same as the segment after /login/ in that link):
# NEXT_PUBLIC_DODO_BUSINESS_ID=YOUR_BUSINESS_ID
# NEXT_PUBLIC_DODO_PAYMENTS_TEST_MODE=true

# Server-only: Dodo (never commit real keys; set in Netlify / CI env)
# Webhook signing secret from Dodo Dashboard  -  Developer  -  Webhooks
# DODO_PAYMENTS_WEBHOOK_KEY=

# Firebase Admin JSON (single line or use Netlify's multiline env for JSON)  -  used only by /api/webhooks/dodo
# Create a service account in GCP with "Firebase Admin" / Firestore access; paste the full JSON.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: local API probe only (GET /api/dodo/ping in development)
# DODO_PAYMENTS_API_BASE=https://live.dodopayments.com
# DODO_PAYMENTS_API_KEY=

# Billing: Firestore billing/{firebaseUid}  -  { soloActive: true } is written by the Dodo webhook (or manually in Console)
