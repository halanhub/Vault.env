# Firebase Configuration
# Create a project at https://console.firebase.google.com
# Enable Authentication: Email/Password + Google (Sign-in method), Firestore, Storage

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional: canonical URLs & Open Graph (e.g. https://yourdomain.com)  -  set in production for SEO
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Optional: Payment Link / checkout URL (e.g. Dodo, Stripe)  -  shown as "Subscribe" in the app header after sign-in
# NEXT_PUBLIC_CHECKOUT_URL=https://...

# Server-only: Dodo Payments API (never use NEXT_PUBLIC_  -  never commit real keys)
# Must match key mode: test dashboard key → https://test.dodopayments.com | live → https://live.dodopayments.com
# DODO_PAYMENTS_API_BASE=https://live.dodopayments.com
# DODO_PAYMENTS_API_KEY=

# Billing: Firestore document billing/{firebaseUid} with { soloActive: true } (set by your webhook or Console) to unlock more than 1 project
