# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Firebase / Google CLI logs (can include account email, paths, token metadata)
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log

# env files  -  NEVER commit real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# private keys & certificates
*.key
*.crt
*.cert
*.p12
*.pfx

# firebase service accounts
*-firebase-adminsdk-*.json
service-account*.json
credentials*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# workspace packages (built output)
packages/*/dist/
